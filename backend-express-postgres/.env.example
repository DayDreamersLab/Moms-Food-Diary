PORT=4000
NODE_ENV=development

# Runtime app connection. Use the least-privileged app role from sql/grant-app-role.sql.
# Local Docker example uses SCRAM-SHA-256 host auth.
DATABASE_URL=postgres://moms_food_diary_app:change-this-app-password@localhost:5432/moms_food_diary
DATABASE_APP_PASSWORD=change-this-app-password

# Admin/migration connection. Do not use this as the runtime DATABASE_URL.
DATABASE_ADMIN_URL=postgres://postgres:change-this-admin-password@localhost:5432/moms_food_diary

# Use a long random value in real deployments.
JWT_SECRET=replace-me-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Comma-separated list of frontend origins allowed to call this API.
CORS_ORIGIN=http://localhost:3000

# Local prototype upload storage. Replace with S3/R2/MinIO for production.
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://localhost:4000
