{
  "name": "moms-food-diary-backend-express-postgres",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:init": "psql \"$DATABASE_URL\" -f sql/schema.sql",
    "db:grant-app-role": "psql \"$DATABASE_ADMIN_URL\" -v app_password=\"$DATABASE_APP_PASSWORD\" -f sql/grant-app-role.sql"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {}
}
